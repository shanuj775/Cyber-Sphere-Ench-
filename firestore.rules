rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CYBER-SPHERE SECURITY RULES
     *
     * PHILOSOPHY:
     * This ruleset enforces a strict User-Ownership model. Access to sensitive data is partitioned 
     * by the user's unique identifier (UID). We utilize Authorization Independence by denormalizing 
     * IDs directly into documents, allowing for high-performance security checks without extra 
     * database lookups.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Root of all user-specific data (Profiles, Scans, Chats, Contacts).
     * - /securityTips, /newsArticles, /cyberAttackReports: Global resources, read-only for users.
     * - /roles_admin: A registry for users with elevated management privileges.
     *
     * KEY DECISIONS:
     * 1. Path-Based Authorization: Most rules rely on the {userId} wildcard in the path.
     * 2. Relational Integrity: On creation, documents must include a 'userId' field matching the path.
     * 3. Prototyping Flexibility: We enforce WHO can write WHAT, but we do not enforce the 
     *    exact internal schema of content fields to allow for rapid development.
     * 4. Admin Roles: We use a "Role-Based Access Control" (RBAC) lookup to authorize global content updates.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the core User Profile. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow get, list, create, update: if request.auth.uid == userId
     * @deny update: if request.auth.uid != userId
     * @principle Self-creation and ownership verification.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for user-owned scan results (Link, Message, Deepfake, File, QR).
       * @path /users/{userId}/{collectionName}/{resultId}
       * @allow create: if isOwner(userId) && request.resource.data.userId == userId
       * @deny create: if request.resource.data.userId != userId
       * @principle Ensures data consistency between path and internal document fields.
       */
      match /linkScanResults/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /messageScanResults/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /deepfakeScanResults/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /fileScanResults/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /qrCodeScanResults/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      /**
       * @description Chat sessions belonging to a user.
       * @path /users/{userId}/chatSessions/{chatSessionId}
       */
      match /chatSessions/{chatSessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);

        /**
         * @description Nested messages within a specific chat session.
         * @path /users/{userId}/chatSessions/{chatSessionId}/messages/{chatMessageId}
         * @principle Relational integrity: chatMessage must belong to the parent session.
         */
        match /messages/{chatMessageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.chatSessionId == chatSessionId;
          allow update, delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Personal safety data: Locations, Emergency Contacts, and Panic Logs.
       * @path /users/{userId}/...
       */
      match /locations/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /emergencyContacts/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }

      match /panicButtonLogs/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global Security Tips: Read-only for users, managed by Admins.
     * @path /securityTips/{id}
     */
    match /securityTips/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global News Articles: Read-only for users, managed by Admins.
     * @path /newsArticles/{id}
     */
    match /newsArticles/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global Cyber Attack Reports: Read-only for users, managed by Admins.
     * @path /cyberAttackReports/{id}
     */
    match /cyberAttackReports/{id} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Admin Role Registry.
     * @path /roles_admin/{userId}
     * @principle Existence-over-Content: A document ID in this collection grants admin powers.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via Firebase Console or Admin SDK for security.
    }
  }
}